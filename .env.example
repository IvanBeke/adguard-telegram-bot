# URL de adguard-sync (opcional, si no se define no se sincroniza)
ADGUARD_SYNC_URL=http://<host>:<port>
# Token del bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# IDs de Telegram autorizados (separados por coma, sin espacios)
ALLOWED_USER_IDS=111111111,222222222

# URL base de AdGuard Home (sin /control al final)
ADGUARD_URL=<host>:<port>

# Credenciales de AdGuard Home
ADGUARD_USER=<user>
ADGUARD_PASSWORD=<password>